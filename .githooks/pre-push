#!/bin/bash

set -Eeuo pipefail

echo "Ejecutando validación previa al push..."

find . \
    -path './.git' -prune -o \
    -type f \
    -name '*.sh' \
    -print0 |
while IFS= read -r -d '' script; do
    bash -n "$script"
done

version=$(tr -d '[:space:]' < VERSION)

if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "ERROR: VERSION no contiene una versión semántica válida." >&2
    exit 1
fi

echo "Versión detectada: $version"
echo "Validación previa al push completada."
