#!/bin/bash

set -Eeuo pipefail

echo "Validando scripts de Backup Manager..."

find . \
    -path './.git' -prune -o \
    -type f \
    -name '*.sh' \
    -print0 |
while IFS= read -r -d '' script; do
    echo "  bash -n $script"
    bash -n "$script"
done

required_files=(
    README.md
    CHANGELOG.md
    LICENSE
    VERSION
    backup.sh
    bootstrap.sh
    config.sh
)

for required_file in "${required_files[@]}"; do
    if [[ ! -s "$required_file" ]]; then
        echo "ERROR: Falta el archivo requerido: $required_file" >&2
        exit 1
    fi
done

echo "Validación del Backup Manager completada."
